{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetNode",
  "version": "0.1.0",
  "identifier": "tech.bytesmind.netnode",
  "build": {
    "beforeDevCommand": "yarn start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist/netnode-web/browser"
  },
  "app": {
    "windows": [
      {
        "title": "NetNode",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws: wss:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/saintbassanaga/netnode-web/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
